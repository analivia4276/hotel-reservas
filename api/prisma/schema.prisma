generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Quarto {
  id          Int      @id @default(autoincrement())
  numero      String
  tipo        String
  reservas    Reserva[]
}

model Reserva {
  id          Int      @id @default(autoincrement())
  hospede     String
  data_entrada  DateTime
  data_saida    DateTime
  quartoId    Int
  quarto      Quarto   @relation(fields: [quartoId], references: [id])
}

